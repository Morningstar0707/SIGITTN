# ══════════════════════════════════════════════════════════════════
#  SIGITTN Backend — Plantilla de variables de entorno
#  Copia a .env y completa los valores. NUNCA subas .env a Git.
# ══════════════════════════════════════════════════════════════════

# ── Base de Datos (Supabase — Transaction Pooler) ─────────────────
# Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.PROYECTO_REF:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Parámetros individuales (solo desarrollo local sin DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sigittn
# DB_USER=postgres
# DB_PASSWORD=

# ── Servidor ──────────────────────────────────────────────────────
# Railway asigna PORT automáticamente. No tocar en producción.
PORT=3001

# ── CORS + Frontend ───────────────────────────────────────────────
# URL exacta de tu frontend en Vercel (sin barra final)
CORS_ORIGIN=https://sigittn.vercel.app
FRONTEND_URL=https://sigittn.vercel.app

# ── JWT ───────────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_ALEATORIA_MUY_LARGA
JWT_EXPIRES_IN=8h

# ── Email — Nodemailer (SMTP) ─────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── Web Push — Claves VAPID ───────────────────────────────────────
# Genera con: npm run vapid:generar
VAPID_EMAIL=tucorreo@gmail.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── NAS — Almacenamiento de Imágenes y Videos ─────────────────────
# URL pública del NAS (Cloudflare Tunnel recomendado)
# Ejemplo con Cloudflare Tunnel: https://nas.tudominio.com
# Ejemplo con IP directa:         http://TU_IP_PUBLICA:8080
NAS_URL=https://nas.tudominio.com

# Clave secreta compartida entre Railway y el servidor NAS
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NAS_UPLOAD_SECRET=CAMBIA_ESTO_POR_OTRA_CLAVE_ALEATORIA
