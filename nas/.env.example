# ══════════════════════════════════════════════════════════
#  SIGITTN NAS Upload API — Variables de entorno
#  Copia a .env y completa los valores reales.
# ══════════════════════════════════════════════════════════

# Puerto interno (solo accesible por nginx en localhost)
PORT=9090

# Directorio raíz donde se guardan los archivos
STORAGE_ROOT=/srv/nas/sigittn

# URL pública del NAS (la que ven los navegadores y Railway)
# Con Cloudflare Tunnel: https://nas.tudominio.com
# Con IP directa:         http://TU_IP_PUBLICA:8080
NAS_PUBLIC_URL=https://nas.tudominio.com

# Clave secreta compartida con Railway (backend)
# Debe ser la misma que NAS_UPLOAD_SECRET en las variables de Railway
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UPLOAD_SECRET=MISMA_CLAVE_QUE_NAS_UPLOAD_SECRET_EN_RAILWAY
